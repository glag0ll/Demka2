<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaApplication6.ViewModels"
             x:Class="AvaloniaApplication6.Views.OrdersView"
             x:DataType="vm:OrdersViewModel">
    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="10">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,10">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                <Image Source="/Assets/logo.png" Width="50" Height="50"/>
                <TextBlock Text="Список заказов" FontSize="20" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentEmployee.Fio}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CurrentEmployee.Post.Name}" FontSize="12" Opacity="0.7" HorizontalAlignment="Right"/>
                </StackPanel>
                <Border Width="60" Height="60" CornerRadius="30" ClipToBounds="True" BorderBrush="#76E383" BorderThickness="2">
                    <Image Source="{Binding EmployeePhoto}" Stretch="UniformToFill"/>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0, 10" HorizontalAlignment="Center">
            <TextBox Text="{Binding SearchText}" Width="250" Watermark="Поиск по коду/клиенту"/>
            <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" Width="180"/>
            <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" Width="180" PlaceholderText="Все статусы">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Сбросить" Command="{Binding LoadDataCommand}"/>
            <Button Content="Добавить заказ" Command="{Binding AddOrderCommand}"/>
            <Button Content="Выйти" Command="{Binding LogoutCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Orders}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0, 10"
                  CanUserSortColumns="True" GridLinesVisibility="All" BorderThickness="1" BorderBrush="#76E383">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="*"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding Datecreate}" Width="*"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding CodeclientNavigation.Fio}" Width="2*"/>
                <DataGridTemplateColumn Header="Услуги" Width="3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ServicesList}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="10, 5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status.Name}" Width="*"/>
                <DataGridTemplateColumn Header="Действия" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="5" HorizontalAlignment="Center">
                                <Button Content="Изменить" Command="{Binding $parent[UserControl].((vm:OrdersViewModel)DataContext).EditOrderCommand}" CommandParameter="{Binding}"
                                        Padding="10, 5" VerticalAlignment="Center"/>
                                <Button Content="Удалить" Command="{Binding $parent[UserControl].((vm:OrdersViewModel)DataContext).DeleteOrderCommand}" CommandParameter="{Binding}"
                                        Padding="10, 5" VerticalAlignment="Center" Background="#FF6B6B" Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="© 2026 Курорт «Игора»" HorizontalAlignment="Center" Margin="5"/>
    </Grid>
</UserControl>
